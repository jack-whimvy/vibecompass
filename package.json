{
  "name": "@vibecompass/vibecompass",
  "version": "0.8.0",
  "description": "Local-first project-memory core for VibeCompass",
  "type": "module",
  "bin": {
    "vibecompass": "src/cli.js"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "CHANGELOG.md",
    "src/*.js",
    "src/generators/**/*.js",
    "src/workflows/**/*.js"
  ],
  "scripts": {
    "test": "node --test src/tests/*.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "vibecompass",
    "project-memory",
    "documentation",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jack-whimvy/vibecompass.git"
  },
  "homepage": "https://github.com/jack-whimvy/vibecompass#readme",
  "bugs": {
    "url": "https://github.com/jack-whimvy/vibecompass/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
